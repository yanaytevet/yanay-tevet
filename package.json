{
  "name": "yanay-tevet-repo-tools",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build:web": "cd yanay-tevet-web && npm run build",
    "build:web:prod": "cd yanay-tevet-web && npm run build:prod",
    "check:backend": "cd yanay_tevet_backend && python -m compileall .",
    "check": "npm run build:web:prod && npm run check:backend"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
